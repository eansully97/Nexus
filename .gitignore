# ============================================================
# Unreal Engine project .gitignore
# Keeps source assets/code/config in git, ignores generated files.
# Tracks Content/Nexus explicitly.
# ============================================================

# --- Unreal generated folders ---
Binaries/
DerivedDataCache/
Intermediate/
Saved/

# Plugin-generated folders
Plugins/*/Binaries/
Plugins/*/Intermediate/
Plugins/*/Saved/

# --- Build / packaging artifacts ---
*.apk
*.app
*.dmg
*.exe
*.ipa
*.msi
*.pak
*.xcodeproj

# --- IDE / project files generated by Unreal or IDEs ---
.vs/
.vscode/
.idea/
*.VC.db
*.VC.opendb
*.sdf
*.suo
*.opensdf
*.user
*.userprefs
*.rsuser
*.sln
*.xcodeproj
*.xcworkspace

# Rider
.idea/
*.DotSettings.user

# --- Logs / temp / OS files ---
*.log
*.tmp
*.temp
.DS_Store
Thumbs.db
Desktop.ini

# --- Python / misc cache files sometimes created by tooling ---
__pycache__/
*.pyc

# ============================================================
# Content strategy
# ============================================================
# Ignore all project content by default, then explicitly track Nexus.
# This is useful if your Content folder is messy and you only want
# your real project assets in source control right now.
Content/*
!Content/Nexus/
!Content/Nexus/**

# If you later want to track more content, add more exceptions like:
# !Content/UI/
# !Content/UI/**
# !Content/Maps/
# !Content/Maps/**

# ============================================================
# Keep these important project files tracked
# ============================================================
!.gitignore
!*.uproject
!Config/**
!Source/**
!Plugins/**/Source/**
!Plugins/**/Content/**
!Plugins/*.uplugin
