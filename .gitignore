# Unreal Engine
# Standard project-wide ignore rules for source control.
# Keeps source assets/code/config, ignores generated files and build artifacts.

# --------------------------------------------------
# Core Unreal generated folders
# --------------------------------------------------
/Binaries/
/DerivedDataCache/
/Intermediate/
/Saved/

/Plugins/**/Binaries/
/Plugins/**/DerivedDataCache/
/Plugins/**/Intermediate/
/Plugins/**/Saved/

# --------------------------------------------------
# Build / package / staging artifacts
# --------------------------------------------------
# Keep Build/ itself because projects may store icons/resources there.
# Ignore common packaged/staged output inside it.
/Build/**/*.pak
/Build/**/*.ucas
/Build/**/*.utoc
/Build/**/*.sig
/Build/**/*.exe
/Build/**/*.app
/Build/**/*.dmg
/Build/**/*.ipa
/Build/**/*.apk
/Build/**/*.aab
/Build/**/*.msi
/Build/**/*.zip
/Build/**/Manifest_*.txt
/Build/**/FileOpenOrder/
/Build/**/Metadata/
/Build/**/StagedBuilds/
/Build/**/Windows/
/Build/**/WindowsNoEditor/
/Build/**/Win64/
/Build/**/Linux/
/Build/**/Mac/
/Build/**/Android/
/Build/**/IOS/

# Common package artifacts anywhere
*.pak
*.ucas
*.utoc
*.sig

# --------------------------------------------------
# IDE / editor files
# --------------------------------------------------
/.vs/
/.vscode/
/.idea/

*.VC.db
*.VC.opendb
*.suo
*.opensdf
*.sdf
*.user
*.userprefs
*.rsuser
*.DotSettings.user
*.opendb
*.idb
*.pdb

# Generated project files
*.sln
*.xcodeproj
*.xcworkspace

# Optional helper file - keep if you want it
!.vsconfig

# --------------------------------------------------
# Logs / temp / cache / OS junk
# --------------------------------------------------
*.log
*.tmp
*.temp
*.cache
*.dmp
*.pid

.DS_Store
Thumbs.db
Desktop.ini

# Python cache (sometimes from helper scripts)
__pycache__/
*.pyc

# --------------------------------------------------
# Optional per-user Unreal config
# --------------------------------------------------
Config/DefaultEditorPerProjectUserSettings.ini
# --------------------------------------------------
# Keep core Unreal project files/folders
# --------------------------------------------------
!.gitignore
!*.uproject
!/Config/**
!/Source/**

# --------------------------------------------------
# Plugins: keep real plugin files, ignore generated
# --------------------------------------------------
!/Plugins/
!/Plugins/**/
!/Plugins/**/*.uplugin
!/Plugins/**/Source/**
!/Plugins/**/Content/**
!/Plugins/**/Resources/**

# --------------------------------------------------
# Content: ignore all, then re-include only Nexus
# --------------------------------------------------
/Content/*
!/Content/Nexus/
!/Content/Nexus/**